# =========================================================
# FACE ID ATTENDANCE + ACCESS CONTROL SYSTEM CONFIG
# =========================================================

# =========================
# DATABASE
# =========================
DB_PATH=data/attendance.db
WEB_REGISTER_PORT=5000

# =========================
# CAMERA SETTINGS
# =========================
# Camera 1 disabled
CAMERA_1_NAME=
CAMERA_1_URL=

# Camera 2: Dahua Entry Camera
CAMERA_2_NAME=Entry Camera
CAMERA_2_URL=rtsp://admin:admin123@192.168.1.80:554/cam/realmonitor?channel=1&subtype=1

# Camera 3: Dahua Exit Camera
CAMERA_3_NAME=Exit Camera
CAMERA_3_URL=rtsp://admin:admin123@192.168.1.81:554/cam/realmonitor?channel=1&subtype=1

# Optional extra cameras
CAMERA_4_NAME=
CAMERA_4_URL=

CAMERA_5_NAME=
CAMERA_5_URL=

# =========================
# CAMERA PERFORMANCE
# =========================
FRAME_SKIP=2
RESIZE_WIDTH=640
RESIZE_HEIGHT=480
CAMERA_TIMEOUT=10
SHOW_CAMERA_PREVIEW=true

# =========================
# FACE RECOGNITION
# =========================
CONFIDENCE_THRESHOLD=0.55
FACE_DETECTION_MODEL=hog
DUPLICATE_TIMEOUT=30
SAVE_UNKNOWN_FACES=true
SAVE_RECOGNIZED_SNAPSHOTS=true

# =========================
# ANTI-SPOOF / LIVENESS
# =========================
ENABLE_LIVENESS_CHECK=false
LIVENESS_MODE=basic
LIVENESS_REQUIRED=false

# =========================
# TURNSTILE / ACCESS CONTROL
# =========================
TURNSTILE_MODE=SIMULATE
TURNSTILE_OPEN_SECONDS=2

RELAY_PORT=/dev/tty.usbserial-0001
RELAY_BAUDRATE=9600

TURNSTILE_API_URL=http://192.168.1.80/api/open
TURNSTILE_API_TOKEN=your_api_token_here

# =========================
# ACCESS HOURS
# =========================
TEACHER_START=07:00
TEACHER_END=16:00

ASSISTANT_START=08:00
ASSISTANT_END=18:00

SECURITY_START=00:00
SECURITY_END=23:59

RECEPTION_START=08:00
RECEPTION_END=18:00

STAFF_START=08:00
STAFF_END=18:00

ADMIN_START=00:00
ADMIN_END=23:59

# =========================
# EVENT TYPE SETTINGS
# =========================
ENTRY_CAMERA_IP=192.168.1.80
EXIT_CAMERA_IP=192.168.1.81
DEFAULT_EVENT_TYPE=ENTRY

# =========================
# UI / DISPLAY
# =========================
SHOW_CONFIDENCE=true
SHOW_ROLE=true
SHOW_STATUS_TEXT=true
SHOW_FPS=false
WINDOW_TITLE=Face ID Attendance System

# =========================
# FILE PATHS
# =========================
PHOTOS_DIR=photos
LOGS_DIR=logs
UNKNOWN_DIR=logs/unknown
SNAPSHOTS_DIR=logs/snapshots

# =========================
# LOGGING
# =========================
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE=logs/system.log

# =========================
# SECURITY / SYSTEM
# =========================
ALLOW_UNKNOWN_ACCESS=false
AUTO_CREATE_DIRS=true
DEBUG=true

# =========================
# DAHUA EVENT LISTENERS
# =========================
ENTRY_CURL_CMD=curl -sk --digest -u admin:admin123 -N -g https://192.168.1.80/cgi-bin/eventManager.cgi?action=attach&codes=[AccessControl,FaceRecognition]&heartbeat=5
EXIT_CURL_CMD=curl -sk --digest -u admin:admin123 -N -g https://192.168.1.81/cgi-bin/eventManager.cgi?action=attach&codes=[AccessControl,FaceRecognition]&heartbeat=5

# =========================
# TELEGRAM BOT
# =========================
TELEGRAM_BOT_TOKEN=8734090030:AAGYV_rBA-gkqg3U4fvvpB_xmfbI0ULK3iQ
TELEGRAM_ADMIN_CHAT_IDS=6716082895